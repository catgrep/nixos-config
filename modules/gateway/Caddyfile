# use caddy's local CA until we're ready to make 'vofi.app' public
{
	local_certs

	# Enable Prometheus metrics on admin API
	servers {
		metrics
	}
	admin :2019
}

jellyfin.vofi.app {
	reverse_proxy ser8.local:8096
}

jellyfin.vofi {
	reverse_proxy ser8.local:8096
}

sonarr.vofi {
	reverse_proxy ser8.local:8989
}

radarr.vofi {
	reverse_proxy ser8.local:7878
}

torrent.vofi {
	reverse_proxy ser8.local:8080
}

prowlarr.vofi {
	reverse_proxy ser8.local:9696
}

sabnzbd.vofi {
	reverse_proxy ser8.local:8085
}

frigate.vofi {
	reverse_proxy ser8.local:80 {
		# WebSocket support required for Frigate live view
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}

hass.vofi {
	reverse_proxy ser8.local:8123 {
		# WebSocket support for Home Assistant
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}

# adguard should be internally accessible only
adguard.internal {
	reverse_proxy pi4.local:3000
}

grafana.vofi.app {
	reverse_proxy firebat.local:3000
}

prometheus.vofi.app {
	reverse_proxy firebat.local:9090
}

# -- Tailscale-exposed services (*.shad-bangus.ts.net)
# These use caddy-tailscale plugin to create separate Tailscale nodes
# Each service gets its own node and DNS entry via MagicDNS
# TLS certificates are obtained automatically via Tailscale's ACME

# -- Media *Arr services
https://jellyfin.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/jellyfin
	reverse_proxy ser8.local:8096
}

https://sabnzbd.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/sabnzbd
	reverse_proxy ser8.local:8085
}

https://radarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/radarr
	reverse_proxy ser8.local:7878
}

https://sonarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/sonarr
	reverse_proxy ser8.local:8989
}

https://prowlarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/prowlarr
	reverse_proxy ser8.local:9696
}

# -- Service monitoring
https://grafana.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/grafana
	reverse_proxy firebat.local:3000
}

https://prom.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/prom
	reverse_proxy firebat.local:9090
}

# -- Smart home devices
https://frigate.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/frigate
	reverse_proxy ser8.local:80 {
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}

https://hass.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/hass
	reverse_proxy ser8.local:8123 {
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}
