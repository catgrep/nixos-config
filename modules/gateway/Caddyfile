	reverse_proxy ser8.internal:8989
}

radarr.vofi {
	reverse_proxy ser8.internal:7878
}

torrent.vofi {
	reverse_proxy ser8.internal:8080
}

prowlarr.vofi {
	reverse_proxy ser8.internal:9696
}

sabnzbd.vofi {
	reverse_proxy ser8.internal:8085
}

# adguard should be internally accessible only
adguard.internal {
	reverse_proxy pi4.internal:3000
}

grafana.vofi.app {
	reverse_proxy firebat.internal:3000
}

prometheus.vofi.app {
	reverse_proxy firebat.internal:9090
}

# Tailscale-exposed services (*.shad-bangus.ts.net)
# These use caddy-tailscale plugin to create separate Tailscale nodes
# Each service gets its own node and DNS entry via MagicDNS
# TLS certificates are obtained automatically via Tailscale's ACME
jellyfin.shad-bangus.ts.net {
	bind tailscale/jellyfin
	reverse_proxy ser8.internal:8096
}

sabnzbd.shad-bangus.ts.net {
	bind tailscale/sabnzbd
	reverse_proxy ser8.internal:8085
}

radarr.shad-bangus.ts.net {
	bind tailscale/radarr
	reverse_proxy ser8.internal:7878
}

sonarr.shad-bangus.ts.net {
	bind tailscale/sonarr
	reverse_proxy ser8.internal:8989
}

prowlarr.shad-bangus.ts.net {
	bind tailscale/prowlarr
	reverse_proxy ser8.internal:9696
}
