# use caddy's local CA until we're ready to make 'vofi.app' public
{
	local_certs
}

jellyfin.vofi.app {
	reverse_proxy ser8.local:8096
}

jellyfin.vofi {
	reverse_proxy ser8.local:8096
}

sonarr.vofi {
	reverse_proxy ser8.local:8989
}

radarr.vofi {
	reverse_proxy ser8.local:7878
}

torrent.vofi {
	reverse_proxy ser8.local:8080
}

prowlarr.vofi {
	reverse_proxy ser8.local:9696
}

sabnzbd.vofi {
	reverse_proxy ser8.local:8085
}

# adguard should be internally accessible only
adguard.internal {
	reverse_proxy pi4.local:3000
}

grafana.vofi.app {
	reverse_proxy firebat.local:3000
}

prometheus.vofi.app {
	reverse_proxy firebat.local:9090
}

# Tailscale-exposed services (*.shad-bangus.ts.net)
# These use caddy-tailscale plugin to create separate Tailscale nodes
# Each service gets its own node and DNS entry via MagicDNS
# TLS certificates are obtained automatically via Tailscale's ACME
https://jellyfin.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/jellyfin
	reverse_proxy ser8.local:8096
}

https://sabnzbd.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/sabnzbd
	reverse_proxy ser8.local:8085
}

https://radarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/radarr
	reverse_proxy ser8.local:7878
}

https://sonarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/sonarr
	reverse_proxy ser8.local:8989
}

https://prowlarr.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/prowlarr
	reverse_proxy ser8.local:9696
}
