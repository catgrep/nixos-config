	reverse_proxy ser8.local:8989
}

radarr.vofi {
	reverse_proxy ser8.local:7878
}

torrent.vofi {
	reverse_proxy ser8.local:8080
}

prowlarr.vofi {
	reverse_proxy ser8.local:9696
}

sabnzbd.vofi {
	reverse_proxy ser8.local:8085
}

frigate.vofi {
	reverse_proxy ser8.local:80 {
		# WebSocket support required for Frigate live view
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}

hass.vofi {
	reverse_proxy ser8.local:8123 {
		# WebSocket support for Home Assistant
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection "Upgrade"
	}
}

# adguard should be internally accessible only
adguard.internal {
	reverse_proxy pi4.local:3000
}

grafana.vofi.app {
	reverse_proxy firebat.local:3000
}

prometheus.vofi.app {
	reverse_proxy firebat.local:9090
}

# -- Tailscale-exposed services (*.shad-bangus.ts.net)
# These use caddy-tailscale plugin to create separate Tailscale nodes
# Each service gets its own node and DNS entry via MagicDNS
# TLS certificates are obtained automatically via Tailscale's ACME
#
# IMPORTANT: Use static IPs (not .local mDNS names) for reverse_proxy backends!
#
# The caddy-tailscale plugin creates virtual Tailscale network nodes that are bound
# to the Tailscale network interface, not the local LAN interface (eno1). This means:
# - mDNS (multicast DNS used by .local names) uses link-local multicast (224.0.0.251)
# - mDNS broadcasts only work on the local network interface where Avahi is listening
# - Tailscale virtual nodes cannot receive these mDNS broadcasts
# - DNS resolution from Tailscale contexts fails intermittently with "device or resource busy"
#
# Debugging this issue (Feb 2026):
# - Observed 502 errors with "dial tcp: lookup ser8.local: device or resource busy"
# - Confirmed mDNS works from firebat host: `ping ser8.local` succeeded
# - But resolution failed from certain contexts: `resolvectl query ser8.local` failed
# - Error specifically appeared in "http.log.error.tailscale" logger (not local sites)
# - Root cause: Tailscale-bound Caddy instances can't access local mDNS broadcasts
# - Solution: Use static IPs (192.168.68.65, etc.) which work reliably from all contexts
#
# Static IP mappings (from deploy.yaml):
# - ser8: 192.168.68.65
# - firebat: 192.168.68.63
# - pi4: 192.168.68.56

# -- Media *Arr services
https://jellyfin.shad-bangus.ts.net {
	log tailscale {
		level DEBUG
	}
	bind tailscale/jellyfin
	reverse_proxy 192.168.68.65:8096
}

