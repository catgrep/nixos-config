# adguard should be internally accessible only
adguard.internal {
	reverse_proxy pi4.internal:3000
}

grafana.vofi.app {
	reverse_proxy firebat.internal:3000
}

prometheus.vofi.app {
	reverse_proxy firebat.internal:9090
}

# Tailscale-exposed services (*.shad-bangus.ts.net)
# These use Tailscale's automatic HTTPS certificate provisioning
jellyfin.shad-bangus.ts.net {
	tls {
		get_certificate tailscale
	}
	reverse_proxy ser8.internal:8096
}

